#!/bin/sh
# Refuse to push if the synced site bar has drifted from components/_site-bar.html.
# Enable once per clone:  git config core.hooksPath tools/git-hooks
python3 "$(git rev-parse --show-toplevel)/tools/sync-nav.py" --check || {
  echo ""
  echo "  push aborted — site bar out of sync."
  echo "  run:  python3 tools/sync-nav.py   then commit the result."
  exit 1
}
